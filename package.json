{
  "name": "whatsopi",
  "version": "0.1.0",
  "description": "AI-powered digital platform for Dominican Republic's informal economy",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "tsc && vite build --mode production",
    "build:sw": "workbox generateSW workbox-config.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix && prettier --write .",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:offline": "vitest --config vitest.offline.config.ts",
    "test:voice": "vitest --config vitest.voice.config.ts",
    "test:whatsapp": "vitest --config vitest.whatsapp.config.ts",
    "pwa:audit": "npx lighthouse --output=json --output-path=./lighthouse-report.json --chrome-flags='--headless' http://localhost:4173",
    "i18n:extract": "i18next-scanner --config i18next-scanner.config.js",
    "i18n:validate": "node scripts/validate-translations.js",
    "whatsapp:test": "node scripts/test-whatsapp-webhook.js",
    "generate:icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-query-devtools": "^5.83.0",
    "axios": "^1.6.2",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "dexie": "^3.2.4",
    "i18next": "^23.7.6",
    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.5.2",
    "react-i18next": "^13.5.0",
    "react-router-dom": "^6.20.1",
    "tailwind-merge": "^2.1.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.1.1",
    "@vitest/ui": "^1.0.4",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "i18next-scanner": "^4.4.0",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.17.4",
    "vitest": "^1.0.4",
    "workbox-cli": "^7.0.0",
    "workbox-precaching": "^7.0.0",
    "workbox-routing": "^7.0.0",
    "workbox-strategies": "^7.0.0"
  },
  "keywords": [
    "dominican-republic",
    "informal-economy",
    "whatsapp",
    "ai",
    "pwa",
    "voice-interface",
    "fintech",
    "colmado"
  ],
  "author": "Armando Diaz Silverio <armando@exxede.com>",
  "license": "MIT"
}
